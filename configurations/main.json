{
  "global_settings": {
    "report_path": "./results_voip/"
  },
  "scenarios": [
    {
      "id": "speed_test_public_server",
      "description": "Speed test results gathered from public server",
      "enabled": false,
      "protocol": "speed_test",
      "schedule": {
        "mode": "recurring",
        "start_time": "immediate",
        "interval_minutes": 60.0,
        "duration_hours": 6.0
      },
      "parameters": {
        "target_url": [
          "23.249.55.42"
        ],
        "duration": 100
      },
      "expectations": [
        {
          "metric": "upload_speed",
          "operator": "lte",
          "value": 15,
          "unit": "mbps",
          "aggregation": "p95",
          "evaluation_scope": "per_iteration"
        }
      ]
    },
    {
      "id": "web_browsing_test",
      "description": "Browsing different URL's on the web",
      "enabled": true,
      "protocol": "web_browsing",
      "schedule": {
        "mode": "recurring",
        "start_time": "immediate",
        "interval_minutes": 1.0,
        "duration_hours": 0.05
      },
      "parameters": {
        "target_url": [
          "https://www.googhgfdghfdle.com"
        ],
        "headless": true,
        "disable_cache": true
      },
      "expectations": [
        {
          "metric": "page_load_time",
          "operator": "lte",
          "value": 10000,
          "unit": "ms",
          "aggregation": "p50",
          "evaluation_scope": "scenario"
        },
        {
          "metric": "http_response_code",
          "operator": "eq",
          "value": 200.0,
          "unit": "code",
          "aggregation": "avg",
          "evaluation_scope": "per_iteration"
        }
      ]
    },
